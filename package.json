{
  "name": "saascription",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "www:dev": "turbo run dev --filter=www",
    "www:build": "turbo run build --filter=www",
    "dash:dev": "turbo run dev --filter=dash",
    "dash:build": "turbo run build --filter=dash",
    "api:dev": "turbo run dev --filter=api",
    "api:deploy": "turbo run deploy --filter=api",
    "lint": "turbo run lint",
    "check": "biome check .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
