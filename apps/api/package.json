{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy --minify",
    "check-types": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 execute saascription --local --file=./db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute saascription --remote --file=./db/schema.sql"
  },
  "dependencies": {
    "@hono/clerk-auth": "^3.1.1",
    "hono": "^4.12.16",
    "svix": "^1.92.2"
  },
  "devDependencies": {
    "typescript": "5.9.2",
    "wrangler": "^4.4.0"
  }
}